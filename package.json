{
  "name": "runtime-architecture-console",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "demo:live": "node scripts/live-tps-demo.mjs",
    "build": "tsc -b && vite build && vite build --config vite.server.config.ts",
    "preview": "npm run start",
    "start": "node dist-server/startServer.js",
    "screenshot:architecture": "npm run build && node scripts/capture-architecture-screenshot.mjs",
    "test": "vitest run --environment jsdom --globals"
  },
  "dependencies": {
    "@xyflow/react": "^12.10.2",
    "lucide-react": "^0.468.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "vite": "^7.0.0",
    "yaml": "^2.6.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.6.0",
    "@testing-library/react": "^16.2.0",
    "@testing-library/user-event": "^14.6.0",
    "@types/node": "^22.10.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "jsdom": "^25.0.0",
    "playwright": "^1.60.0",
    "typescript": "^5.8.0",
    "vitest": "^3.0.0"
  }
}
